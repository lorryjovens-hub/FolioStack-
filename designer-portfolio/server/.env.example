# Server Configuration
NODE_ENV=development
PORT=3002
API_BASE_URL=http://localhost:3002/api

# Database Configuration (Docker环境下使用服务名)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=foliostack
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Redis Configuration (Docker环境下使用服务名)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
MAX_ZIP_SIZE=104857600
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg
ALLOWED_DOCUMENT_TYPES=application/pdf,application/zip,application/x-rar-compressed

# Storage Configuration
STORAGE_TYPE=local
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Proxy Configuration
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Deployment Configuration
DEPLOY_BASE_URL=https://foliostack.app
DEPLOY_DIR=./deployments

# AI Service Configuration (Doubao/Volcengine)
AI_API_KEY=your-api-key
AI_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/coding
AI_MODEL=doubao-seed-2.0-code
ENABLE_AI_FEATURES=true

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production
CSRF_SECRET=your-csrf-secret-change-in-production

# Email Configuration (for password reset, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@foliostack.app

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# GitHub Integration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3002/api/auth/github/callback

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_AI_FEATURES=false
ENABLE_DEPLOY_FEATURES=true
