# =============================================================================
# FolioStack 环境配置文件
# 说明：复制此文件为 .env 并填入实际值
# 安全提示：永远不要将 .env 文件提交到 Git 仓库
# =============================================================================

# =============================================================================
# 核心安全配置 (必需)
# =============================================================================

# JWT 认证密钥 - 用于签名和验证 JWT Token
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production_min_32_chars

# JWT Token 过期时间
JWT_EXPIRES_IN=7d

# 会话加密密钥 - 用于加密用户会话数据
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_key_here_change_in_production_min_32_chars

# =============================================================================
# 服务器配置
# =============================================================================

# 服务器端口 (Vercel 会自动分配端口)
PORT=3002

# 环境模式: development | production | test
NODE_ENV=development

# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# =============================================================================
# 数据库配置 (二选一)
# =============================================================================

# -----------------------------------------------------------------------------
# 选项 1: Turso 云服务数据库 (推荐用于生产环境)
# 注册: https://turso.tech
# 创建数据库后获取连接信息
# -----------------------------------------------------------------------------
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# -----------------------------------------------------------------------------
# 选项 2: PostgreSQL (可选)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:foliostack_secure_password_2024@localhost:5432/foliostack
DB_PASSWORD=foliostack_secure_password_2024

# -----------------------------------------------------------------------------
# 选项 3: 本地 SQLite (开发环境默认)
# 无需配置，自动使用 ./data/portfolio.db
# -----------------------------------------------------------------------------

# =============================================================================
# Redis 缓存配置 (可选)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=foliostack_redis_secure_password
REDIS_URL=redis://localhost:6379

# =============================================================================
# 网站配置
# =============================================================================

# 网站主URL (生产环境必须修改)
SITE_URL=http://localhost:3000

# CORS 允许的源 (多个用逗号分隔)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# =============================================================================
# 文件上传配置
# =============================================================================
UPLOAD_DIR=./uploads
DEPLOY_DIR=./deployments
MAX_FILE_SIZE=10485760

# =============================================================================
# AI 服务配置 (可选)
# =============================================================================
OPENAI_API_KEY=sk-your_openai_api_key_here
ARK_API_KEY=your_ark_api_key_here

# =============================================================================
# 邮件服务配置 (可选)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@foliostack.com

# =============================================================================
# OAuth 登录配置 (可选)
# =============================================================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# 监控和分析 (可选)
# =============================================================================
SENTRY_DSN=your_sentry_dsn_here
ANALYTICS_ID=your_analytics_id_here

# =============================================================================
# 安全提示
# =============================================================================
# 1. JWT_SECRET 和 SESSION_SECRET 必须使用强随机字符串 (至少64字符)
# 2. 生产环境必须设置 NODE_ENV=production
# 3. 永远不要提交 .env 文件到版本控制
# 4. 定期更换密钥以增强安全性
# 5. 使用 HTTPS 协议保护数据传输
# 6. 数据库密码应包含大小写字母、数字和特殊字符
# 7. 启用双因素认证 (2FA) 保护敏感账户
# =============================================================================
